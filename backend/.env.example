# Example backend env (safe to commit). Replace placeholders before use.
SECRET_KEY=REPLACE_WITH_SECRET_KEY
DEBUG=False
ALLOWED_HOSTS=yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Appwrite
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=REPLACE_WITH_APPWRITE_PROJECT_ID
APPWRITE_API_KEY=REPLACE_WITH_APPWRITE_API_KEY
APPWRITE_DB_ID=sgep_db

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# Email
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=webmaster@yourdomain.com

# JWT lifetimes
JWT_ACCESS_TOKEN_LIFETIME=900
JWT_REFRESH_TOKEN_LIFETIME=604800
