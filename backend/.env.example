# Copy to .env.local for real credentials (gitignored). Committed defaults use placeholders below.
SECRET_KEY=change-me-in-production
DEBUG=False
# Local dev defaults. On Render, RENDER_EXTERNAL_HOSTNAME is injected automatically
# (e.g. sgep-i2b9.onrender.com) and appended to ALLOWED_HOSTS in settings.py.
# Optional override: ALLOWED_HOSTS=localhost,127.0.0.1,sgep-i2b9.onrender.com
ALLOWED_HOSTS=localhost,127.0.0.1
# Add your Vercel frontend URL in production, e.g. https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000

APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_DB_ID=sgep_db
MEDICAL_ENCRYPTION_KEY=

REDIS_URL=redis://redis:6380/0
CELERY_BROKER_URL=redis://redis:6380/1

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com

JWT_ACCESS_TOKEN_LIFETIME=900
JWT_REFRESH_TOKEN_LIFETIME=604800

# One-time bootstrap (sans accès shell Render) : POST /api/v1/auth/bootstrap/
# Header: X-Bootstrap-Token: <valeur>. Supprimer cette variable après création du 1er admin.
BOOTSTRAP_SECRET=
